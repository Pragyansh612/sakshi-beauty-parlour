# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real secrets

# Supabase project URL (find in Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key — safe to use in browser code
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role key — SECRET, server-only, never expose to browser
# Used only in scripts (seed-images.ts) — do not use in Next.js app code
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site URL — used for auth redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
